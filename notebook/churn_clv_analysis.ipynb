   "source": [
    "## Core libraries\n",
    "import pandas as pd\n",
    "import numpy as np\n",
"import shap"
"shap.initjs()"  "# for JS visualizations"

# This avoids the notebook progress bar warning
"shap.explainers._legacy._tqdm = lambda *args, **kwargs: iter(args[0])"
    "\n",
    "# Visualization\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.express as px\n",
    "\n",
    "# Data preprocessing\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.impute import SimpleImputer\n",
    "\n",
    "# Machine learning models\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier, RandomForestRegressor, VotingClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "# Evaluation metrics\n",
    "from sklearn.metrics import accuracy_score, classification_report, roc_auc_score, mean_squared_error, r2_score\n",
    "\n",
    "# Model explainability\n",
    "import shap\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "dbb02f1a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load dataset \n",
    "data = pd.read_csv('../data/bank_customers_large.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "2afc07d3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic data cleaning and missing value handling\n",
    "for col in data.columns:\n",
    "\n",
    "    if data[col].dtype == 'object':\n",
    "        # Attempt to convert object columns to numeric\n",
    "        numeric_col = pd.to_numeric(data[col], errors='coerce')\n",
    "\n",
    "        if numeric_col.notna().any():\n",
    "            # If conversion is valid, treat as numeric and fill missing with median\n",
    "            data[col] = numeric_col\n",
    "            data[col].fillna(data[col].median(), inplace=True)\n",
    "        else:\n",
    "            # Otherwise, treat as categorical and fill missing with mode\n",
    "            mode_val = data[col].mode(dropna=True)\n",
    "            if not mode_val.empty:\n",
    "                data[col].fillna(mode_val.iloc[0], inplace=True)\n",
    "            else:\n",
    "                # Fallback for columns with all missing values\n",
    "                data[col].fillna('Unknown', inplace=True)\n",
    "    else:\n",
    "        # Fill missing numeric values with median\n",
    "        if data[col].isna().any():\n",
    "            data[col].fillna(data[col].median(), inplace=True)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "da759e20",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
